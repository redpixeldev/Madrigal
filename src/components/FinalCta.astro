---
import Icon from '@components/Icon.astro';
import { waLink } from '@/consts';
---

<section class='bg-cream-deep pb-20 pt-4 sm:pb-24'>
	<div class='container'>
		<div
			class='relative overflow-hidden rounded-3xl bg-gradient-to-br from-copper to-copper-deep px-6 py-16 text-center sm:px-12 sm:py-20'
		>
			<!-- decorative circles -->
			<div
				class='pointer-events-none absolute -left-10 -top-10 size-40 rounded-full bg-white/10'
				aria-hidden='true'>
			</div>
			<div
				class='pointer-events-none absolute -bottom-16 -right-10 size-56 rounded-full bg-white/10'
				aria-hidden='true'>
			</div>

			<div class='relative mx-auto max-w-2xl'>
				<h2 class='text-3xl font-medium leading-tight text-white sm:text-4xl'>¿Listo para dar el paso?</h2>
				<p class='mx-auto mt-4 max-w-xl text-base leading-relaxed text-white/85'>
					Escríbenos y te decimos qué tenemos disponible hoy. Sin compromiso, con la confianza de una asesoría cercana.
				</p>
				<a
					href={waLink()}
					target='_blank'
					rel='noopener'
					class='btn mt-8 bg-white px-7 py-3.5 text-base text-copper-deep hover:bg-cream'
				>
					<Icon
						name='whatsapp'
						size={20}
					/>
					Consultar disponibilidad por WhatsApp
				</a>
			</div>
		</div>
	</div>
</section>
