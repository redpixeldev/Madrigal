---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Hero from '@components/Hero.astro';
import PropertyTypes from '@components/PropertyTypes.astro';
import AvailabilityBand from '@components/AvailabilityBand.astro';
import WhyMadrigal from '@components/WhyMadrigal.astro';
import Process from '@components/Process.astro';
import Testimonials from '@components/Testimonials.astro';
import About from '@components/About.astro';
import FinalCta from '@components/FinalCta.astro';
import WhatsAppFab from '@components/WhatsAppFab.astro';
---

<Layout>
	<Header />
	<main id='contenido'>
		<Hero />
		<PropertyTypes />
		<AvailabilityBand />
		<WhyMadrigal />
		<Process />
		<Testimonials />
		<About />
		<FinalCta />
	</main>
	<Footer />
	<WhatsAppFab />
</Layout>
