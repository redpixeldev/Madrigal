---
interface Props {
	eyebrow: string;
	title: string;
	subtitle?: string;
	align?: 'center' | 'left';
	id?: string;
}

const { eyebrow, title, subtitle, align = 'center', id } = Astro.props;
const isCenter = align === 'center';
---

<div class={isCenter ? 'mx-auto max-w-[640px] text-center' : 'max-w-[640px]'}>
	<p class='mb-3.5 text-[12.5px] font-bold uppercase tracking-[2px] text-copper-dark'>{eyebrow}</p>
	<h2
		id={id}
		class='font-heading text-[clamp(28px,3.6vw,44px)] font-semibold leading-[1.1] tracking-[-0.5px] text-ink'
	>
		{title}
	</h2>
	{subtitle && <p class='mt-3.5 text-[16px] font-light leading-[1.65] text-gray'>{subtitle}</p>}
</div>
