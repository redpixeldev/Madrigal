---
import SectionHeading from '@components/SectionHeading.astro';
import { STEPS } from '@/consts';
---

<section
	id='proceso'
	class='border-y border-copper/50 px-6 py-16'
>
	<div class='mx-auto max-w-[1180px]'>
		<SectionHeading
			eyebrow='Cómo trabajamos'
			title='Un proceso simple, de principio a fin'
		/>

		<ol class='relative mt-[60px] grid gap-[18px] sm:grid-cols-2 lg:grid-cols-4'>
			<!-- dashed connecting line (desktop) -->
			<div
				class='absolute left-[12%] right-[12%] top-[31px] hidden h-[2px] bg-[repeating-linear-gradient(90deg,#d9cdba_0_8px,transparent_8px_16px)] lg:block'
				aria-hidden='true'>
			</div>

			{
				STEPS.map((step, i) => {
					const isLast = i === STEPS.length - 1;
					return (
						<li class='relative text-center'>
							<span
								class:list={[
									'relative z-10 mx-auto mb-[22px] flex size-16 items-center justify-center rounded-full border-2 font-heading text-[22px] font-bold',
									isLast
										? 'border-copper bg-copper text-white shadow-[0_14px_28px_-14px_rgba(205,161,118,0.85)]'
										: 'border-[#e2d8c8] bg-white text-copper shadow-[0_12px_26px_-16px_rgba(74,79,84,0.5)]',
								]}
							>
								{step.number}
							</span>
							<h3 class='mb-[9px] font-heading text-[17px] font-semibold text-ink'>{step.title}</h3>
							<p class='text-[14.5px] font-normal leading-[1.6] text-gray'>{step.description}</p>
						</li>
					);
				})
			}
		</ol>
	</div>
</section>
