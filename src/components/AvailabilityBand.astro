---
import Icon from '@components/Icon.astro';
import { waLink, CONTACT } from '@/consts';
---


<section class='bg-cream-deep pb-20 sm:pb-24'>
	<div class='container'>
		<div class='relative overflow-hidden rounded-3xl bg-white px-6 py-14 text-center shadow-sm shadow-slate/5 sm:px-12'>
			<!-- decorative corner -->
			<div
				class='pointer-events-none absolute -right-16 -top-16 size-48 rounded-full bg-copper/10'
				aria-hidden='true'>
			</div>

			<div class='relative mx-auto max-w-xl'>
				<span class='mx-auto flex size-16 items-center justify-center rounded-full bg-cream'>
					<img
						src='/img/icon-disponibilidad.png'
						alt=''
						class='size-10'
						width='240'
						height='240'
					/>
				</span>

				<p class='mt-6 text-xs font-semibold uppercase tracking-[0.22em] text-copper'>Disponibilidad en tiempo real</p>
				<h2 class='mt-3 text-3xl font-medium leading-tight text-slate sm:text-4xl'>
					El inventario se mueve rápido. Lo de hoy quizá no esté mañana.
				</h2>
				<p class='mt-4 text-base leading-relaxed text-gray'>
					Por eso no publicamos un catálogo fijo. Escríbenos por WhatsApp y te enviamos las opciones disponibles ahora
					mismo, según tu zona y tu presupuesto.
				</p>

				<a
					href={waLink()}
					target='_blank'
					rel='noopener'
					class='btn btn-primary mt-8 px-7 py-3.5 text-base'
				>
					<Icon
						name='whatsapp'
						size={20}
					/>
					Escríbenos por WhatsApp
				</a>

				<p class='mt-4 text-sm text-gray-mute'>
					Te decimos qué tenemos disponible hoy · {CONTACT.phoneDisplay}
				</p>
			</div>
		</div>
	</div>
</section>
