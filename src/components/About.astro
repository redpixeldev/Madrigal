---
import Icon from '@components/Icon.astro';
import { waLink } from '@/consts';
---

<section
	id='nosotros'
	class='px-6 py-16'
>
	<div class='mx-auto max-w-[1180px]'>
		<div class='grid items-center gap-14 lg:grid-cols-[1.05fr_0.95fr]'>
			<div>
				<p class='mb-3.5 text-[12.5px] font-bold uppercase tracking-[2px] text-copper-dark'>Sobre nosotros</p>
				<h2
					class='mb-[22px] font-heading text-[clamp(28px,3.6vw,44px)] font-semibold leading-[1.1] tracking-[-0.5px] text-ink'
				>
					Más que cerrar una venta, nos importa tu decisión
				</h2>
				<p class='mb-[18px] text-[17px] font-normal leading-[1.75] text-slate-soft'>
					Somos asesores inmobiliarios en República Dominicana enfocados en un trato humano. Te acompañamos con
					honestidad, paciencia y conocimiento del mercado local, desde la primera conversación hasta que recibes tus
					llaves.
				</p>
				<p class='mb-[30px] text-[17px] font-normal leading-[1.75] text-slate-soft'>
					Ya sea que busques tu primera vivienda, un apartamento para invertir o un solar para construir, estamos para
					que tomes una buena decisión, con calma y bien informado.
				</p>
				<a
					href={waLink('Hola Madrigal, quiero que me asesoren.')}
					target='_blank'
					rel='noopener'
					class='inline-flex items-center gap-[10px] rounded-full bg-copper px-7 py-[15px] text-[16px] font-bold text-white shadow-[0_14px_30px_-14px_rgba(205,161,118,0.85)] transition-colors hover:bg-copper-dark'
				>
					<Icon
						name='whatsapp'
						size={23}
					/>
					Hablemos por WhatsApp
				</a>
			</div>

			<div class='relative'>
				<div class='aspect-[4/5] overflow-hidden rounded-[26px] shadow-[0_40px_74px_-38px_rgba(74,79,84,0.5)]'>
					<img
						src='/img/about.webp'
						alt='Asesores de Madrigal Realty acompañando a una pareja en la búsqueda de su hogar.'
						class='size-full object-cover'
						width='1000'
						height='1250'
						loading='lazy'
					/>
				</div>
				<div
					class='absolute right-[-18px] top-[30px] rounded-[16px] bg-white px-5 py-3.5 shadow-[0_24px_50px_-24px_rgba(74,79,84,0.5)]'
				>
					<p class='font-heading text-[15px] font-semibold text-ink'>Trato 100% humano</p>
					<p class='text-[13px] text-gray-soft'>de principio a fin</p>
				</div>
			</div>
		</div>
	</div>
</section>
