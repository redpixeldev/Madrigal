---
import Icon from '@components/Icon.astro';
import { waLink, CONTACT } from '@/consts';
---

<section class='px-6 pt-7 sm:pt-16 pb-16'>
	<div
		class='relative mx-auto max-w-[920px] overflow-hidden rounded-[30px] bg-white p-[clamp(24px,6vw,72px)] sm:p-[clamp(40px,6vw,72px)] text-center shadow-[0_40px_80px_-44px_rgba(74,79,84,0.5)]'
	>
		<!-- decorative corner -->
		<div
			class='pointer-events-none absolute -right-[60px] -top-[60px] size-[160px] sm:size-[200px] rounded-full bg-[#f6f0e7]'
			aria-hidden='true'>
		</div>

		<div class='relative'>
			<span
				class='mx-auto mb-6 flex size-[72px] items-center justify-center rounded-full bg-cream-deep text-copper'
			>
				<img
					src='/img/icon-disponibilidad.png'
					alt=''
					class='size-[42px] object-contain'
					width='240'
					height='240'
				/>
			</span>

			<p class='mb-3.5 text-[12.5px] font-bold uppercase tracking-[2px] text-copper-dark'>Disponibilidad en tiempo real</p>
			<h2
				class='mx-auto mb-[18px] max-w-[640px] font-heading text-[clamp(27px,3.6vw,42px)] font-semibold leading-[1.1] tracking-[-0.5px] text-ink'
			>
				El inventario se mueve rápido. Lo de hoy quizá no esté mañana.
			</h2>
			<p class='mx-auto mb-8 max-w-[560px] text-[17px] font-normal leading-[1.7] text-gray'>
				Por eso no publicamos un catálogo fijo. Escríbenos por WhatsApp y te enviamos las opciones disponibles ahora
				mismo, según tu zona y tu presupuesto.
			</p>

			<a
				href={waLink('Hola Madrigal, ¿qué tienen disponible hoy?')}
				target='_blank'
				rel='noopener'
				class='inline-flex items-center gap-[11px] whitespace-nowrap rounded-full bg-copper px-[34px] py-[17px] text-[17px] font-bold text-white shadow-[0_16px_34px_-12px_rgba(205,161,118,0.85)] transition-colors hover:bg-copper-dark max-[767px]:px-7 max-md:text-[16px] max-[529px]:px-5'
			>
				<Icon
					name='whatsapp'
					size={26}
				/>
				Escríbenos por WhatsApp
			</a>

			<p class='mt-4 text-[13.5px] font-light text-gray-mute'>
				Te decimos qué tenemos disponible hoy · {CONTACT.phoneDisplay}
			</p>
		</div>
	</div>
</section>
