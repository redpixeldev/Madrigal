---
import SectionHeading from '@components/SectionHeading.astro';
import { TESTIMONIALS } from '@/consts';

const initials = (name: string) =>
	name
		.split(' ')
		.slice(0, 2)
		.map((n) => n[0])
		.join('')
		.toUpperCase();
---

<section class='bg-white px-6 py-16'>
	<div class='mx-auto max-w-[1180px]'>
		<SectionHeading
			eyebrow='Testimonios'
			title='Lo que dicen quienes ya dieron el paso'
		/>

		<div
			class='testimonials-swiper swiper mt-[50px]'
			role='region'
			aria-roledescription='carrusel'
			aria-label='Testimonios de clientes'
		>
			<div class='swiper-wrapper'>
				{
					TESTIMONIALS.map((t) => (
						<div class='swiper-slide h-auto'>
							<figure class='flex h-full flex-col rounded-[22px] bg-cream px-[30px] py-8'>
								<span
									class='block h-[26px] font-heading text-[44px] leading-[0.5] text-copper'
									aria-hidden='true'
								>
									“
								</span>
								<blockquote class='mb-[22px] flex-1 text-[16px] font-normal leading-[1.65] text-slate'>{t.quote}</blockquote>
								<figcaption class='flex items-center gap-[13px]'>
									<span
										class='flex size-12 shrink-0 items-center justify-center rounded-full bg-copper/15 text-sm font-bold text-copper-deep'
										aria-hidden='true'
									>
										{initials(t.name)}
									</span>
									<span>
										<span class='block text-[14.5px] font-bold text-ink'>{t.name}</span>
										<span class='block text-[13px] text-gray-mute'>{t.location}</span>
									</span>
								</figcaption>
							</figure>
						</div>
					))
				}
			</div>
			<div class='swiper-pagination !static mt-8 lg:!hidden'></div>
		</div>
	</div>
</section>

<style is:global>
	.testimonials-swiper {
		--swiper-pagination-color: var(--color-copper);
		--swiper-pagination-bullet-inactive-color: var(--color-line);
		--swiper-pagination-bullet-inactive-opacity: 1;
	}
</style>

<script is:inline>
	(function initTestimonials() {
		if (typeof window.Swiper === 'undefined') {
			return window.setTimeout(initTestimonials, 40);
		}
		new window.Swiper('.testimonials-swiper', {
			slidesPerView: 1,
			spaceBetween: 24,
			grabCursor: true,
			a11y: { enabled: true },
			pagination: { el: '.testimonials-swiper .swiper-pagination', clickable: true },
			breakpoints: {
				640: { slidesPerView: 2 },
				1024: { slidesPerView: 3 },
			},
		});
	})();
</script>
