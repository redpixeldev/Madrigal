---
// Reusable inline-SVG icon set. Line icons use `currentColor` so they inherit
// the brand copper via Tailwind text-* utilities. Decorative by default
// (aria-hidden); pass a title/aria-label on the parent for meaningful icons.
interface Props {
	name: string;
	class?: string;
	size?: number;
}

const { name, class: className = '', size = 24 } = Astro.props;
---

{
	name === 'whatsapp' && (
		<svg class={className} width={size} height={size} viewBox='0 0 24 24' fill='none' aria-hidden='true'>
			<path
				d='M12 2.6a9.4 9.4 0 0 0-8.1 14.16L2.6 21.4l4.77-1.27A9.4 9.4 0 1 0 12 2.6Z'
				stroke='currentColor'
				stroke-width='1.5'
				stroke-linejoin='round'
			/>
			<path
				d='M9.07 7.6c-.18-.42-.36-.42-.54-.43h-.46c-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2 0 1.18.86 2.32.98 2.48.12.16 1.68 2.68 4.12 3.66 2.04.82 2.46.66 2.9.62.44-.04 1.42-.58 1.62-1.14.2-.56.2-1.04.14-1.14-.06-.1-.22-.16-.46-.28-.24-.12-1.42-.7-1.64-.78-.22-.08-.38-.12-.54.12-.16.24-.62.78-.76.94-.14.16-.28.18-.52.06-.24-.12-1.02-.38-1.94-1.2-.72-.64-1.2-1.42-1.34-1.66-.14-.24-.02-.37.1-.49.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.54-1.36-.76-1.85Z'
				fill='currentColor'
			/>
		</svg>
	)
}
{
	name === 'menu' && (
		<svg class={className} width={size} height={size} viewBox='0 0 24 24' aria-hidden='true'>
			<g fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round'>
				<line x1='4' y1='7' x2='20' y2='7' />
				<line x1='4' y1='12' x2='20' y2='12' />
				<line x1='4' y1='17' x2='20' y2='17' />
			</g>
		</svg>
	)
}
{
	name === 'close' && (
		<svg class={className} width={size} height={size} viewBox='0 0 24 24' aria-hidden='true'>
			<g fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round'>
				<line x1='6' y1='6' x2='18' y2='18' />
				<line x1='18' y1='6' x2='6' y2='18' />
			</g>
		</svg>
	)
}
{
	name === 'arrow-right' && (
		<svg class={className} width={size} height={size} viewBox='0 0 24 24' aria-hidden='true'>
			<g fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'>
				<line x1='4' y1='12' x2='19' y2='12' />
				<polyline points='13 6 19 12 13 18' />
			</g>
		</svg>
	)
}
{
	name === 'chat-check' && (
		<svg class={className} width={size} height={size} viewBox='0 0 32 32' aria-hidden='true'>
			<g fill='none' stroke='currentColor' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'>
				<path d='M5 20.5V11a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v3.5a4 4 0 0 1-4 4h-7l-5 4v-4H9a4 4 0 0 1-4-4Z' />
				<line x1='10' y1='12.5' x2='10' y2='12.5' />
				<line x1='14' y1='12.5' x2='14' y2='12.5' />
				<line x1='18' y1='12.5' x2='18' y2='12.5' />
				<circle cx='24' cy='22' r='5' fill='currentColor' stroke='none' />
				<polyline points='21.8 22 23.4 23.6 26.4 20.4' stroke='#fff' stroke-width='1.6' />
			</g>
		</svg>
	)
}
{
	name === 'home-heart' && (
		<svg class={className} width={size} height={size} viewBox='0 0 32 32' aria-hidden='true'>
			<g fill='none' stroke='currentColor' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'>
				<path d='M5 14 16 5l11 9' />
				<path d='M7.5 12.5V25a1.5 1.5 0 0 0 1.5 1.5h14a1.5 1.5 0 0 0 1.5-1.5V12.5' />
