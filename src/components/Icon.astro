				<polyline points='12.5 13 14 14.5 16.5 12' />
				<line x1='18.5' y1='13.2' x2='20' y2='13.2' />
				<polyline points='12.5 18 14 19.5 16.5 17' />
				<line x1='18.5' y1='18.2' x2='20' y2='18.2' />
			</g>
		</svg>
	)
}
{
	name === 'search-buildings' && (
		<svg class={className} width={size} height={size} viewBox='0 0 32 32' aria-hidden='true'>
			<g fill='none' stroke='currentColor' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'>
				<path d='M5 25h7V12l5-3v16' />
				<path d='M8 25v-6' />
				<circle cx='20' cy='14' r='6' />
				<line x1='24.4' y1='18.4' x2='28' y2='22' />
				<line x1='18' y1='13' x2='18' y2='13' />
				<line x1='22' y1='13' x2='22' y2='13' />
			</g>
		</svg>
	)
}
{
	name === 'shield-person' && (
		<svg class={className} width={size} height={size} viewBox='0 0 32 32' aria-hidden='true'>
