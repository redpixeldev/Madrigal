---
import Icon from '@components/Icon.astro';
import { NAV_LINKS, CONTACT, waLink, SITE } from '@/consts';

const year = new Date().getFullYear();
const footerNav = NAV_LINKS.filter((l) => l.href !== '#contacto');
---

<footer
	id='contacto'
	class='rounded-t-[36px] bg-[#3a3e42] px-6 pb-9 pt-[72px]'
>
	<div class='mx-auto max-w-[1180px]'>
		<div
			class='grid gap-12 border-b border-[#4d5258] pb-12 lg:grid-cols-[1.4fr_1fr_1fr]'
		>
			<!-- Brand -->
			<div>
				<img
					src='/img/logo-light.png'
					alt={`${SITE.name} · ${SITE.tagline}`}
					class='mb-[22px] h-[62px] w-auto'
					width='480'
					height='282'
				/>
				<p class='max-w-[330px] text-[15px] font-normal leading-[1.65] text-[#c2c7cb]'>
					Asesoría inmobiliaria cercana en República Dominicana. Casas, apartamentos, solares y proyectos en planos.
				</p>
			</div>

			<!-- Navigation -->
			<nav aria-label='Enlaces del pie de página'>
				<h2 class='mb-[18px] text-[13px] font-bold uppercase tracking-[1.5px] text-copper'>Navegación</h2>
				<ul class='flex flex-col gap-[11px] text-[15px] font-normal'>
					{
						footerNav.map((link) => (
							<li>
								<a
									href={link.href}
									class='text-[#c6cace] transition-colors hover:text-white'
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<!-- Contact (icons kept) -->
			<div>
				<h2 class='mb-[18px] text-[13px] font-bold uppercase tracking-[1.5px] text-copper'>Contacto</h2>
				<ul class='flex flex-col gap-[11px] text-[15px] font-normal text-[#d0d4d8]'>
					<li>
						<a
							href={waLink()}
							target='_blank'
							rel='noopener'
							class='flex items-center gap-3 transition-colors hover:text-white'
						>
							<Icon
								name='whatsapp'
								size={18}
								class='shrink-0 text-copper'
							/>
							WhatsApp · {CONTACT.phoneDisplay}
						</a>
					</li>
					<li>
						<a
							href={`tel:+${CONTACT.whatsapp}`}
							class='flex items-center gap-3 transition-colors hover:text-white'
						>
							<Icon
								name='phone'
								size={18}
								class='shrink-0 text-copper'
							/>
							Tel. {CONTACT.phoneDisplay}
						</a>
					</li>
					<li>
						<a
							href={`mailto:${CONTACT.email}`}
							class='flex items-center gap-3 transition-colors hover:text-white'
						>
							<Icon
								name='mail'
								size={18}
								class='shrink-0 text-copper'
							/>
							{CONTACT.email}
						</a>
					</li>
					<li>
						<a
							href={CONTACT.instagramUrl}
							target='_blank'
							rel='noopener'
							class='flex items-center gap-3 transition-colors hover:text-white'
						>
							<Icon
								name='instagram'
								size={18}
								class='shrink-0 text-copper'
							/>
							Instagram · @{CONTACT.instagram}
						</a>
					</li>
					<li class='flex items-center gap-3 text-[#b3b8bd]'>
						<Icon
							name='map-pin'
							size={18}
							class='shrink-0 text-copper'
						/>
						{CONTACT.location}
					</li>
				</ul>
			</div>
		</div>

		<div
			class='flex flex-wrap items-center justify-between gap-4 pt-[26px] text-[13.5px] font-normal text-[#aeb4ba]'
		>
			<span>© {year} {SITE.name} · {SITE.tagline}. Todos los derechos reservados.</span>
		</div>
	</div>
</footer>
