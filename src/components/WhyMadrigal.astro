---
import SectionHeading from '@components/SectionHeading.astro';
import { FEATURES } from '@/consts';
---

<section class='bg-white px-6 py-16'>
	<div class='mx-auto max-w-[1180px]'>
		<SectionHeading
			eyebrow='Por qué Madrigal'
			title='Una asesoría cercana en la que puedes confiar'
		/>

		<ul class='mt-[52px] grid gap-[22px] sm:grid-cols-2 lg:grid-cols-4'>
			{
				FEATURES.map((feature) => (
					<li class='rounded-[22px] bg-cream px-7 py-[34px] text-center'>
						<span class='mx-auto mb-5 flex size-[84px] items-center justify-center rounded-full bg-white shadow-[0_10px_22px_-14px_rgba(74,79,84,0.5)]'>
							<img
								src={feature.icon}
								alt=''
								class='size-[55px] object-contain'
								width='240'
								height='240'
								loading='lazy'
							/>
						</span>
						<h3 class='mb-[9px] font-heading text-[18px] font-semibold text-ink'>{feature.title}</h3>
						<p class='text-[14.5px] font-normal leading-[1.6] text-gray'>{feature.description}</p>
					</li>
				))
			}
		</ul>
	</div>
</section>
